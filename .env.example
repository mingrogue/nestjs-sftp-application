# SFTP Configuration
SFTP_HOST=sftp
SFTP_PORT=22
SFTP_USERNAME=user
SFTP_PASSWORD=password
SFTP_PRIVATE_KEY_PATH=
SFTP_REMOTE_PATH=/upload
SFTP_POLL_INTERVAL_MS=5000

# Kafka Configuration
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=sftp-source
KAFKA_TOPIC=sftp-documents

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Application Configuration
PORT=3000
